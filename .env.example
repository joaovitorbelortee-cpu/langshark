# ─── HTTP ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
RELOAD=

# ─── Auth do webhook (mesmo formato do bot antigo) ──────
# A Evolution manda o header `apikey: $WEBHOOK_SECRET`
WEBHOOK_SECRET=troque-isso-por-um-segredo-forte

# ─── Evolution API (WhatsApp) ────────────────────────────
EVOLUTION_API_URL=https://sua-evolution.example.com
EVOLUTION_API_KEY=chave-da-evolution
EVOLUTION_INSTANCE=botzap

# ─── LLM (OpenRouter como hub, igual ao bot antigo) ──────
# Pode usar OPENAI_API_KEY direto se preferir só OpenAI.
OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=
AI_MODEL=openai/gpt-4o-mini
AI_BASE_URL=https://openrouter.ai/api/v1
AI_REFERRER=https://bot-vendas.local

# ─── Redis (Upstash REST) ────────────────────────────────
# Usado pra queue FIFO, locks, lead_facts fallback, unread buffer.
# Sem essas duas, cai num fallback in-memory (só dev).
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ─── Redis TCP nativo (langgraph-checkpoint-redis) ───────
# OPCIONAL: se setado, vira o checkpointer + store preferido (sobre Postgres).
# Upstash oferece endpoint TCP: rediss://default:senha@host:6379
# Pode usar Redis Cloud, Railway Redis plugin, Aiven, etc.
# Sem REDIS_URL, sistema usa POSTGRES_URL como checkpointer.
REDIS_URL=
STORE_TTL_DAYS=90    # TTL default dos itens no store (refresh on read)

# ─── RAG ChromaDB ────────────────────────────────────────
CHROMA_DIR=./chroma_db

# ─── Multi-tenant ────────────────────────────────────────
DEFAULT_PROJECT_ID=padrao
